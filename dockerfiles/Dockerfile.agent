# ===========================================
# OpenClaw Agent Dockerfile
# ===========================================
# Base: Node.js 24 on Debian Bookworm (stable, widely compatible)
FROM node:24-bookworm-slim

# Build arguments for customization
ARG OPENCLAW_VERSION=2026.3.13
ARG USER_ID=1000
ARG GROUP_ID=1000

# Environment setup
ENV NODE_ENV=production \
    DEBIAN_FRONTEND=noninteractive \
    HOME=/home/node

# Install system dependencies (python, make, g++ for native modules like better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Note: Node.js 24+ images already include a 'node' user (UID 1000, GID 1000)
# If custom UID/GID is needed, uncomment and modify the following:
# RUN usermod -u ${USER_ID} node && groupmod -g ${GROUP_ID} node

# Install OpenClaw globally
RUN npm install -g openclaw@${OPENCLAW_VERSION}

# Create application directories
RUN mkdir -p /app/data /app/workspace /app/results /app/user-files /app/config /app/skills-dist /app/cli \
    && chown -R node:node /app

# Set working directory for skills build
WORKDIR /app

# Copy skills package files first for dependency caching
COPY --chown=node:node ./src/skills/package.json /tmp/skills-build/package.json
COPY --chown=node:node ./src/skills/tsconfig.json /tmp/skills-build/tsconfig.json

# Install skills dependencies (including better-sqlite3)
RUN cd /tmp/skills-build && npm install --production=false

# Copy skills source code
COPY --chown=node:node ./src/skills/ /tmp/skills-build/

# Build skills (output goes to ./dist relative to tsconfig)
RUN cd /tmp/skills-build && npm run build

# Move built files to final location (preserving directory structure)
# TypeScript compiles to /tmp/skills-build/dist/ with structure like:
#   dist/web-search/index.js
#   dist/grok-search/index.js
#   etc.
RUN mkdir -p /app/skills-dist && \
    cp -r /tmp/skills-build/dist/* /app/skills-dist/ && \
    # Copy node_modules for better-sqlite3 and other dependencies
    cp -r /tmp/skills-build/node_modules /app/skills-dist/ && \
    # Cleanup build directory
    rm -rf /tmp/skills-build

# Copy skill-runner script
COPY --chown=node:node ./src/scripts/skill-runner.mjs /app/cli/skill-runner.mjs
RUN chmod +x /app/cli/skill-runner.mjs

# Copy configuration and script files
COPY --chown=node:node ./src/config/ /app/config/
COPY --chown=node:node ./src/scripts/ /app/scripts/

# Copy OpenClaw skill definitions (SKILL.md files) to skills directory
RUN mkdir -p /app/skills/web-search \
    /app/skills/grok-search \
    /app/skills/data-extraction \
    /app/skills/math-operations \
    /app/skills/document-creation \
    /app/skills/notifications \
    /app/skills/scheduling

COPY --chown=node:node ./src/skills/web-search/SKILL.md /app/skills/web-search/SKILL.md
COPY --chown=node:node ./src/skills/grok-search/SKILL.md /app/skills/grok-search/SKILL.md
COPY --chown=node:node ./src/skills/data-extraction/SKILL.md /app/skills/data-extraction/SKILL.md
COPY --chown=node:node ./src/skills/math-operations/SKILL.md /app/skills/math-operations/SKILL.md
COPY --chown=node:node ./src/skills/document-creation/SKILL.md /app/skills/document-creation/SKILL.md
COPY --chown=node:node ./src/skills/notifications/SKILL.md /app/skills/notifications/SKILL.md
COPY --chown=node:node ./src/skills/scheduling/SKILL.md /app/skills/scheduling/SKILL.md

# Prepare OpenClaw config directory
RUN mkdir -p /home/node/.openclaw/ && chown -R node:node /home/node/.openclaw/
RUN chmod +x /app/scripts/app-entrypoint.sh

# Switch to non-root user
USER node

# Expose OpenClaw gateway port
EXPOSE 18789

# Health check - use TCP socket test since gateway speaks WebSocket
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD bash -c 'echo > /dev/tcp/localhost/18789' || exit 1

# Default command - start OpenClaw gateway
# Use --allow-unconfigured for initial setup without pre-configuration
# Use loopback binding (default) - Docker port mapping handles external access
# Port 18789 is the default gateway port
ENTRYPOINT ["/app/scripts/app-entrypoint.sh"]
CMD ["openclaw", "gateway", "run", "--port", "18789", "--allow-unconfigured"]