# ===========================================
# Web Interface Dockerfile
# ===========================================
# Multi-stage build for optimized image size

# Stage 1: Build React frontend
FROM node:24-bookworm-slim AS frontend-builder

WORKDIR /app/frontend

# Copy frontend package files
COPY ./src/frontend/package*.json ./

# Install all dependencies (including devDependencies) for build
RUN npm install

# Copy frontend source
COPY ./src/frontend/ ./

# Build React app
RUN npm run build

# Stage 2: Build Node.js API
FROM node:24-bookworm-slim AS api-builder

WORKDIR /app

# Copy API package files
COPY ./src/api/package*.json ./

# Install all dependencies (including devDependencies) for TypeScript compilation
RUN npm install

# Copy API source
COPY ./src/api/ ./

# Build TypeScript if needed
RUN if [ -f tsconfig.json ]; then npm run build; fi

# Stage 3: Production image with Nginx
FROM node:24-bookworm-slim

# Install Nginx
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create app directories
RUN mkdir -p /app/api /app/frontend /app/results /var/log/app

# Copy built frontend from builder stage
COPY --from=frontend-builder /app/frontend/build /var/www/html

# Copy built API from builder stage
COPY --from=api-builder /app/dist /app/api/dist
COPY --from=api-builder /app/node_modules /app/api/node_modules
COPY --from=api-builder /app/package.json /app/api/

# Copy Nginx configuration
COPY ./dockerfiles/nginx.conf /etc/nginx/nginx.conf
COPY ./dockerfiles/nginx-default.conf /etc/nginx/sites-available/default

# Create startup script
RUN echo '#!/bin/bash\n\
set -e\n\
# Start Node.js API in background\n\
cd /app/api && node dist/index.js &\n\
# Start Nginx in foreground\n\
nginx -g "daemon off;"\n\
' > /app/start.sh && chmod +x /app/start.sh

# Expose web interface port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:80/health || exit 1

# Start services
CMD ["/app/start.sh"]