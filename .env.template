# ===========================================
# Mini Agent Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -----------------------------------------
# Agent Configuration
# -----------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

WEB_APP_BASE_PATH=/app
WEB_DATABASE_PATH=/app/data/tasks.db

# -----------------------------------------
# Model Provider Configuration
# -----------------------------------------
# Primary provider: ollama, anthropic, openai
DEFAULT_PROVIDER=ollama

# Ollama Configuration (local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=api-key

# Anthropic Configuration (cloud fallback)
# ANTHROPIC_API_KEY=your-api-key-here

# OpenAI Configuration (cloud fallback)
# OPENAI_API_KEY=your-api-key-here

# -----------------------------------------
# Web Interface Configuration
# -----------------------------------------
# Web UI credentials (change these!)
WEB_USERNAME=admin
WEB_PASSWORD=change-me-secure-password

# Session secret for JWT
SESSION_SECRET=change-me-random-string-32-chars

# -----------------------------------------
# Discord Bot Configuration
# -----------------------------------------
# Get your bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# DISCORD_CLIENT_ID=your-discord-client-id

# -----------------------------------------
# Notification Configuration
# -----------------------------------------
# Email notifications via Amazon SES
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
# NOTIFICATION_EMAIL=your-email@example.com

# -----------------------------------------
# Security Configuration
# -----------------------------------------
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080

# JWT token expiration (in seconds)
JWT_EXPIRATION=86400