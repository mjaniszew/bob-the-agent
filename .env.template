# ===========================================
# Mini Agent Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -----------------------------------------
# Agent Configuration
# -----------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

APP_BASE_PATH=/app

# -----------------------------------------
# Model Provider Configuration
# -----------------------------------------
# Primary provider: ollama, anthropic, openai
DEFAULT_PROVIDER=ollama

# Ollama Configuration (local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=api-key

# Anthropic Configuration (cloud fallback)
# ANTHROPIC_API_KEY=your-api-key-here

# OpenAI Configuration (cloud fallback)
# OPENAI_API_KEY=your-api-key-here

# -----------------------------------------
# x.AI (Grok) Configuration
# -----------------------------------------
# API key for Grok Search API (web and X search)
# Get your key from https://console.x.ai/
# XAI_API_KEY=your-xai-api-key-here

# Session secret for JWT
SESSION_SECRET=change-me-random-string-32-chars

# -----------------------------------------
# Discord Bot Configuration
# -----------------------------------------
# Get your bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# DISCORD_CLIENT_ID=your-discord-client-id

# -----------------------------------------
# AWS
# -----------------------------------------
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# -----------------------------------------
# Email notifications via Amazon SES
# -----------------------------------------
# AWS_REGION=us-east-1
# NOTIFICATION_EMAIL=your-email@example.com
# -----------------------------------------
# AWS_S3 Configuration
# -----------------------------------------
# AWS_S3_BUCKET=gnomes-test
# AWS_S3_REGION=eu-central-1

# JWT token expiration (in seconds)
JWT_EXPIRATION=86400