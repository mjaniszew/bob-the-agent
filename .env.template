# ===========================================
# Bob The Agent Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -----------------------------------------
# Agent Configuration
# -----------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info
APP_BASE_PATH=/app

# Anthropic Configuration (cloud fallback)
# ANTHROPIC_API_KEY=your-api-key-here

# OpenAI Configuration (cloud fallback)
# OPENAI_API_KEY=your-api-key-here

# -----------------------------------------
# x.AI (Grok) Configuration
# -----------------------------------------
# API key for X.com (Twitter) search via Grok API
# IMPORTANT: Use a separate key from XAI_API_KEY to prevent OpenClaw from
# consuming tokens for web search. SearXNG is used for web search (free).
# Get your key from https://console.x.ai/
# XAI_SEARCH_API_KEY=your-xai-search-api-key-here

# Main x.AI API key (optional, for other Grok features)
# XAI_API_KEY=your-xai-api-key-here

# API key for X.com (Twitter) search via it's api directly
# X_COM_API_TOKEN=your-x-com-api-token

# -----------------------------------------
# Discord Bot Configuration
# -----------------------------------------
# Get your bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# DISCORD_CLIENT_ID=your-discord-client-id

# -----------------------------------------
# AWS
# -----------------------------------------
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# -----------------------------------------
# Email notifications via Amazon SES
# -----------------------------------------
# AWS_REGION=us-east-1
# NOTIFICATION_EMAIL=your-email@example.com
# -----------------------------------------
# AWS_S3 Configuration
# -----------------------------------------
# AWS_S3_BUCKET=gnomes-test
# AWS_S3_REGION=eu-central-1

# -----------------------------------------
# SearXNG Configuration
# -----------------------------------------
# Secret key for SearXNG instance (generate a random string)
# SEARXNG_SECRET_KEY=your-random-secret-key-here
# SEARXNG_VERSION=latest
SEARXNG_BASE_URL=http://searxng:8888